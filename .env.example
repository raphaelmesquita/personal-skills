# ChatGPT Resets Notifier
# Use "telegram" or "email".
NOTIFY_CHANNEL=telegram
TIMEZONE=America/Sao_Paulo

# Telegram configuration.
# Create a bot with @BotFather, send a message to it, then get your chat id from:
# https://api.telegram.org/botSEU_TOKEN/getUpdates
TELEGRAM_BOT_TOKEN=seu_token_do_bot
TELEGRAM_CHAT_ID=seu_chat_id

# SMTP email configuration. Required only when NOTIFY_CHANNEL=email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM=seu_email@gmail.com
EMAIL_TO=seu_email@gmail.com
